# --- LLM provider selection ---
LLM_PROVIDER=anthropic        # one of: anthropic | bedrock | openai

# --- Anthropic API (default) ---
ANTHROPIC_API_KEY=
MODEL_ID=claude-sonnet-4-6

# --- AWS Bedrock (alternate) ---
AWS_REGION=us-east-1
AWS_PROFILE=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-v1:0

# --- OpenAI (alternate) ---
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-4o-mini

# --- Agent runtime ---
MAX_TOKENS=2048
TEMPERATURE=0.7
LOG_LEVEL=INFO
