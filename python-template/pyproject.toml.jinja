[build-system]
requires = ["uv_build>=0.4.0"]
build-backend = "uv_build"

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.12"
authors = [{ name = "{{ github_username }}" }]
dependencies = [
    "pydantic>=2.7",
    "pydantic-settings>=2.4",
    "python-dotenv>=1.0",
    "anthropic>=0.39",
    "boto3>=1.35",
    "streamlit>=1.39",
    "rich>=13.9",
    "loguru>=0.7",
    "pydantic-ai>=0.0.14",
]

[project.scripts]
{{ project_slug_underscore }} = "{{ project_slug_underscore }}.__main__:cli"

[dependency-groups]
dev = [
    "pytest>=8.3",
    "pytest-cov>=5.0",
    "ruff>=0.7",
    "ty>=0.0.1a1",
    "pre-commit>=4.0",
    "mkdocs-material>=9.5",
    "mkdocstrings[python]>=0.26",
    "mkdocs-gen-files>=0.5",
    "mkdocs-literate-nav>=0.6",
    "mkdocs-section-index>=0.3",
    "mkdocs-autorefs>=1.2",
    "marimo>=0.9",
]

[tool.ruff]
line-length = 100
target-version = "py312"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "SIM", "RUF"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-ra --cov={{ project_slug_underscore }} --cov-report=term-missing"
